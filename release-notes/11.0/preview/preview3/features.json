      "is_security": false,
      "local_repo_commit": "runtime@d3f8a05",
      "labels": ["area-CodeGen-coreclr", "runtime-async"],
      "score": 6,
      "score_reason": "JIT optimization that reduces work per continuation save when locals haven't changed"
    },
    {
