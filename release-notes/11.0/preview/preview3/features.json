      "is_security": false,
      "local_repo_commit": "runtime@a0e5f72",
      "labels": ["area-crossgen2-coreclr", "runtime-async"],
      "score": 7,
      "score_reason": "Enables ahead-of-time compilation for runtime-async methods in crossgen2, widening platform support for the Runtime Async preview feature"
    },
    {
