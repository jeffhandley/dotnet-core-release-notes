      "labels": ["area-Diagnostics-coreclr", "runtime-async"],
      "score": 6,
      "score_reason": "Diagnostic/profiler support for runtime-async methods; needed for profiler, debugger, and sampling tool integration"
    },
    {
      "id": "runtime@c2e7f94",
      "repo": "runtime",
      "product": "dotnet-runtime",
      "title": "Add runtime async support for saving and reusing continuation instances",
      "url": "https://github.com/dotnet/runtime/pull/125556",
