      "is_security": false,
      "local_repo_commit": "runtime@c2e7f94",
      "labels": ["area-VM-coreclr", "runtime-async"],
      "score": 7,
      "score_reason": "Memory efficiency: continuation instances can now be reused rather than re-allocated, reducing GC pressure in high-async-throughput workloads"
    },
    {
      "id": "runtime@d3f8a05",
      "repo": "runtime",
      "product": "dotnet-runtime",
      "title": "JIT: Add a runtime async optimization to skip saving unmutated locals into reused continuations",
